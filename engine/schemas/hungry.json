{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hungry-platform-schema",
  "version": "1.0.0",
  "name": "Hungry",
  "description": "Schema for parsing Hungry Food Partner Order Form PDFs (Catering)",

  "platform_info": {
    "platform_id": "hungry",
    "business_client": "Group - Hungry",
    "document_types": ["cover_sheet", "order_labels"],
    "combined_document": false,
    "order_type": "catering"
  },

  "detection": {
    "description": "Patterns to identify this PDF as a Hungry order",
    "method": "pattern_match",
    "min_matches": 2,
    "patterns": [
      "FOOD PARTNER ORDER FORM",
      "tryhungry\\.com",
      "HUNGRY",
      "Chef Dashboard",
      "FP NETWORK",
      "PAYOUT TOTAL",
      "Food Partner:"
    ]
  },

  "document_structure": {
    "description": "Hungry provides separate cover sheet and labels PDFs",
    "pages": {
      "cover_sheet": {
        "page_range": [1, 1],
        "contains": ["order_info", "items_table", "totals"]
      },
      "labels": {
        "separate_document": true,
        "contains": ["item_labels"],
        "repeating": true
      }
    }
  },

  "extraction_rules": {

    "main_order_info": {
      "description": "Order-level information from cover sheet",
      "source_pages": [1],

      "fields": {
        "order_number": {
          "pattern": "Order Number:\\s*(\\w+)",
          "group": 1,
          "type": "string",
          "required": true
        },

        "order_date": {
          "pattern": "Order Date:\\s*(\\d{1,2}/\\d{1,2}/\\d{4})",
          "group": 1,
          "type": "date",
          "format": "M/D/YYYY",
          "required": true
        },

        "pickup_time": {
          "pattern": "(?:Estimated )?Pick-?Up Time:\\s*(\\d{1,2}:\\d{2}\\s*(?:am|pm)?)",
          "group": 1,
          "type": "time",
          "required": true,
          "flags": "i"
        },

        "headcount": {
          "pattern": "Headcount:\\s*(\\d+)",
          "group": 1,
          "type": "integer",
          "required": true
        },

        "setup_style": {
          "pattern": "Setup Style:\\s*([^\\n]+)",
          "group": 1,
          "type": "string",
          "post_process": ["trim"]
        },

        "meal_type": {
          "pattern": "Meal Type:\\s*([^\\n]+)",
          "group": 1,
          "type": "string",
          "post_process": ["trim"]
        },

        "food_partner": {
          "description": "This is the client for Hungry orders",
          "pattern": "Food Partner:\\s*([^\\n]+)",
          "group": 1,
          "type": "string",
          "required": true,
          "maps_to": "client_name"
        },

        "pickup_address": {
          "pattern": "Pickup Address:\\s*([^\\n]+(?:\\n[^\\n]+)?)",
          "group": 1,
          "type": "string",
          "post_process": ["normalize_whitespace", "trim"]
        },

        "manager_name": {
          "pattern": "Manager:\\s*([^\\n]+?)(?:Email|$)",
          "group": 1,
          "type": "string",
          "post_process": ["trim"]
        },

        "manager_email": {
          "pattern": "Email:\\s*(\\S+@\\S+)",
          "group": 1,
          "type": "email"
        },

        "manager_phone": {
          "pattern": "Phone:\\s*([+\\d\\-\\s]+)",
          "group": 1,
          "type": "phone"
        },

        "sales_rep": {
          "pattern": "Sales Rep:\\s*([^\\n]+)",
          "group": 1,
          "type": "string"
        },

        "contact": {
          "pattern": "Contact:\\s*([^\\n]+)",
          "group": 1,
          "type": "string"
        },

        "payout_total": {
          "pattern": "PAYOUT TOTAL\\s*\\$?([\\d,]+\\.?\\d*)",
          "group": 1,
          "type": "currency",
          "maps_to": "order_subtotal"
        },

        "processing_fee": {
          "pattern": "PAYMENT PROCESSING FEE\\s*\\(\\$?([\\d.]+)\\)",
          "group": 1,
          "type": "currency"
        }
      }
    },

    "guest_sections": {
      "description": "Hungry is catering - no individual guests, items are bulk",
      "type": "catering",
      "section_detection": {
        "method": "item_table",
        "description": "Items listed in table format, not per-guest"
      }
    },

    "individual_orders": {
      "description": "For Hungry, each item type becomes an 'individual order' with servings as quantity",
      "source": "items_table",

      "item_detection": {
        "method": "pattern_split",
        "pattern": "([A-Za-z][A-Za-z'\\s]+(?:Bowl|Salad|Wrap|Meal|Plate)?(?:\\s+w/\\s+\\w+)?)\\s*-\\s*1\\s*-\\s*(\\d+)\\s+\\$([\\d.]+)",
        "description": "Matches 'Item Name - 1 - Servings $Price'",
        "captures": {
          "item_name": 1,
          "servings": 2,
          "payout": 3
        }
      },

      "item_block": {
        "start": "item_name pattern",
        "end": "next item_name pattern OR PAYMENT PROCESSING",
        "contains": ["description", "allergens", "tags", "packaging"]
      },

      "fields": {
        "item_name": {
          "source": "item_header",
          "capture_group": 1,
          "type": "string",
          "required": true
        },

        "servings": {
          "source": "item_header",
          "capture_group": 2,
          "type": "integer",
          "required": true
        },

        "payout": {
          "source": "item_header",
          "capture_group": 3,
          "type": "currency"
        },

        "description": {
          "method": "next_lines",
          "count": 2,
          "join": " ",
          "end_before": "Contains:|Vendor Notes:|Packaging:",
          "type": "string"
        },

        "allergens": {
          "pattern": "Contains:\\s*([^\\n]+?)(?:\\s+Other Tags:|$)",
          "group": 1,
          "type": "string",
          "split_by": ",",
          "output_type": "array"
        },

        "dietary_tags": {
          "pattern": "Other Tags:\\s*([^\\n]+)",
          "group": 1,
          "type": "string",
          "split_by": ",",
          "output_type": "array"
        },

        "packaging": {
          "pattern": "Packaging:\\s*([^\\n]+)",
          "group": 1,
          "type": "string"
        },

        "vendor_notes": {
          "pattern": "Vendor Notes:\\s*([^\\n]+)",
          "group": 1,
          "type": "string"
        }
      },

      "output_structure": {
        "description": "For catering, create one record per item type (not per serving)",
        "guest_name_template": "Catering ({servings} servings)",
        "modifications_from": ["allergens", "dietary_tags", "packaging"]
      }
    },

    "labels_document": {
      "description": "Separate labels PDF - extract item counts by counting occurrences",
      "item_detection": {
        "pattern": "^([A-Za-z][A-Za-z'\\s]+(?:Bowl|Salad|Wrap)?(?:\\s+w/\\s+\\w+)?)$",
        "multiline": true
      },
      "extract_per_label": {
        "item_name": {
          "pattern": "^([A-Za-z][A-Za-z'\\s]+(?:Bowl|Salad|Wrap|Meal)?)",
          "group": 1
        },
        "description": {
          "method": "lines_after_header",
          "count": 3,
          "join": " "
        },
        "dietary_info": {
          "pattern": "((?:vegan|prepared without gluten|contains)[^\\n]+)",
          "group": 1
        }
      }
    }
  },

  "post_processing": {
    "modifications_vs_comments": {
      "description": "For catering, dietary info goes to modifications",
      "modification_sources": ["allergens", "dietary_tags"],
      "comment_sources": ["vendor_notes", "packaging"]
    },

    "text_cleanup": {
      "remove_patterns": [
        "CONSUMING RAW OR UNDERCOOKED.*$",
        "The Payout Total is the exact amount.*$"
      ],
      "normalize_whitespace": true
    }
  },

  "output_mapping": {
    "main_order_information": {
      "business_client": {"source": "platform_info.business_client"},
      "client_name": {"source": "main_order_info.food_partner"},
      "client_information": {
        "template": "{pickup_address}, Manager: {manager_name}, Email: {manager_email}, Phone: {manager_phone}",
        "sources": {
          "pickup_address": "main_order_info.pickup_address",
          "manager_name": "main_order_info.manager_name",
          "manager_email": "main_order_info.manager_email",
          "manager_phone": "main_order_info.manager_phone"
        }
      },
      "order_subtotal": {"source": "main_order_info.payout_total"},
      "requested_pick_up_time": {"source": "main_order_info.pickup_time"},
      "requested_pick_up_date": {"source": "main_order_info.order_date"},
      "number_of_guests": {"source": "main_order_info.headcount"},
      "delivery": {"value": "Pickup"}
    },

    "group_orders": {
      "group_order_number": {"source": "main_order_info.order_number"},
      "pick_time": {"source": "main_order_info.pickup_time"}
    },

    "individual_orders": {
      "group_order_number": {"source": "main_order_info.order_number"},
      "guest_name": {"template": "Catering ({servings} servings)"},
      "item_name": {"source": "individual_orders.item_name"},
      "modifications": {
        "combine": ["allergens", "dietary_tags"],
        "format": "Contains: {allergens} | Tags: {dietary_tags}"
      },
      "comments": {"source": "individual_orders.packaging"}
    }
  },

  "examples": {
    "item_sample": {
      "input": "Chicken Shawarma Bowl - 1 - 10 $139.00\nChicken Shawarma, Spanakorizo, Roasted Cauliflower, Baby Zucchini, Aleppo Chickpeas, Moroccan\nCarrots, Feta, Hummus + Yogurt Dill Sauce\nContains: sesame, allium Other Tags: prepared without gluten\nVendor Notes:\nPackaging: 10x Individually Packaged",
      "expected_output": {
        "item_name": "Chicken Shawarma Bowl",
        "servings": 10,
        "payout": 139.00,
        "allergens": ["sesame", "allium"],
        "dietary_tags": ["prepared without gluten"],
        "packaging": "10x Individually Packaged"
      }
    }
  }
}
