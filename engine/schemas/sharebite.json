{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sharebite-platform-schema",
  "version": "1.0.0",
  "name": "Sharebite",
  "description": "Schema for parsing Sharebite group order PDFs",

  "platform_info": {
    "platform_id": "sharebite",
    "business_client": "Group - Sharebite",
    "document_types": ["cover_sheet", "order_labels", "order_table"],
    "combined_document": true,
    "order_type": "individual_orders"
  },

  "detection": {
    "description": "Patterns to identify this PDF as a Sharebite order",
    "method": "pattern_match",
    "min_matches": 2,
    "patterns": [
      "care@sharebite\\.com",
      "Handled by Sharebite",
      "sharebite",
      "Sharebite",
      "GO\\s*#",
      "\\+ x1",
      "Individual Orders"
    ]
  },

  "document_structure": {
    "description": "Sharebite combines cover, table, and label pages in one PDF",
    "pages": {
      "cover_sheet": {
        "detection": "contains order summary and totals",
        "contains": ["order_info", "totals", "delivery_info"]
      },
      "order_table": {
        "detection": "contains QTY column header",
        "contains": ["items_table"]
      },
      "order_labels": {
        "detection": "contains 'Slip 1 of 1'",
        "contains": ["individual_slips"],
        "repeating": true
      }
    }
  },

  "extraction_rules": {

    "main_order_info": {
      "description": "Order-level information from cover sheet",
      "source_pages": [1],

      "text_preprocessing": {
        "dedupe_bold": true,
        "description": "Sharebite PDFs have doubled characters from bold text rendering"
      },

      "fields": {
        "order_number": {
          "pattern": "GO\\s*#?\\s*([A-Z0-9]+)",
          "group": 1,
          "type": "string",
          "required": true,
          "dedupe_bold": true
        },

        "order_date": {
          "pattern": "(\\w{3}\\s+\\d{1,2},?\\s*\\d{4})",
          "group": 1,
          "type": "date",
          "required": true
        },

        "pickup_time": {
          "pattern": "(?:PICKUP AT|READY BY)[:\\s]+(\\d+:\\d+\\s*(?:AM|PM)?)",
          "group": 1,
          "type": "time",
          "flags": "i"
        },

        "client_name": {
          "method": "first_match",
          "patterns": [
            {
              "pattern": "^([A-Za-z][A-Za-z\\s]+)\\s*-\\s*\\w+\\s+\\w+\\s*\\([^)]+\\)",
              "group": 1,
              "multiline": true
            },
            {
              "method": "section_extract",
              "section_start": "Address:",
              "line_index": 0
            }
          ],
          "type": "string",
          "required": true,
          "dedupe_bold": true
        },

        "address": {
          "method": "section_extract",
          "section_start": "Address:",
          "section_end": "Delivery Instructions|$",
          "skip_lines": 0,
          "join_lines": true,
          "type": "string"
        },

        "phone": {
          "pattern": "\\(?\\d{3}\\)?[\\s.-]?\\d{3}[\\s.-]?\\d{4}",
          "group": 0,
          "type": "phone"
        },

        "guest_count": {
          "pattern": "(\\d+)\\s+Individual Orders",
          "group": 1,
          "type": "integer",
          "dedupe_bold": true
        },

        "item_count": {
          "pattern": "(\\d+)\\s+Items",
          "group": 1,
          "type": "integer"
        },

        "subtotal": {
          "pattern": "Subtotal:\\s*\\$?([\\d.]+)",
          "group": 1,
          "type": "currency"
        },

        "delivery_type": {
          "method": "conditional",
          "conditions": [
            {"pattern": "PICKUP", "value": "Pickup", "flags": "i"},
            {"pattern": "DELIVERY", "value": "Delivery", "flags": "i"}
          ],
          "default": "Pickup"
        }
      }
    },

    "guest_sections": {
      "description": "Individual guest orders from slips or table",
      "type": "individual_orders",

      "slip_format": {
        "detection": "Slip 1 of 1",
        "section_split": "Slip 1 of 1",
        "guest_pattern": "([A-Z]\\.[\\s]*[A-Za-z]+)\\s*(FL\\d+)?",
        "captures": {
          "guest_name": 1,
          "floor_location": 2
        }
      },

      "table_format": {
        "detection": "QTY|ORDER",
        "row_pattern": "(\\d+)x\\s+(.+?)\\s+([A-Z]\\.[\\s]*[A-Za-z]+)\\s*(FL\\d+)?\\s*\\$([\\d.]+)",
        "captures": {
          "quantity": 1,
          "item_name": 2,
          "guest_name": 3,
          "floor_location": 4,
          "price": 5
        }
      }
    },

    "individual_orders": {
      "description": "Extract individual guest orders",
      "sources": ["slip_format", "table_format"],
      "priority": "slip_format",

      "fields": {
        "guest_name": {
          "source": "section_header",
          "capture_group": 1,
          "type": "string",
          "required": true,
          "dedupe_bold": true
        },

        "floor_location": {
          "source": "section_header",
          "capture_group": 2,
          "type": "string"
        },

        "items": {
          "slip_format": {
            "pattern": "(\\d+)x\\s+(.+)",
            "captures": {
              "quantity": 1,
              "item_name": 2
            }
          },
          "table_format": {
            "from_row": true
          }
        },

        "modifications": {
          "slip_format": {
            "pattern": "•\\s*(.+)",
            "collect_all": true
          },
          "table_format": {
            "pattern": "(.+?)\\s+\\+\\s*x1\\s+(.+)",
            "format": "{category}: {value}",
            "captures": {
              "category": 1,
              "value": 2
            }
          },
          "type": "array"
        },

        "special_instructions": {
          "pattern": "SP:\\s*(.+)",
          "group": 1,
          "type": "string",
          "maps_to": "comments"
        },

        "price": {
          "pattern": "\\$([\\d.]+)",
          "group": 1,
          "type": "currency",
          "scope": "item_line"
        }
      },

      "output_structure": {
        "repeat_for_each": "items",
        "inherit_fields": ["guest_name", "floor_location"]
      }
    }
  },

  "post_processing": {
    "text_preprocessing": {
      "dedupe_bold": {
        "description": "Remove duplicate adjacent characters from bold text",
        "method": "character_dedupe"
      }
    },

    "modifications_vs_comments": {
      "comment_indicators": [
        "SP:",
        "\\bplease\\b",
        "\\bprefer",
        "\\ballergy"
      ],
      "modification_sources": ["bullet_points", "plus_x1_format"]
    },

    "text_cleanup": {
      "remove_patterns": [
        "Terra - Eat Better Food",
        "care@sharebite\\.com",
        "\\(800\\)[\\d\\-\\s]+",
        "Pg \\d+ of \\d+"
      ]
    }
  },

  "output_mapping": {
    "main_order_information": {
      "business_client": {"source": "platform_info.business_client"},
      "client_name": {"source": "main_order_info.client_name"},
      "client_information": {
        "template": "{address}, Phone: {phone}",
        "sources": {
          "address": "main_order_info.address",
          "phone": "main_order_info.phone"
        }
      },
      "order_subtotal": {"source": "main_order_info.subtotal"},
      "requested_pick_up_time": {"source": "main_order_info.pickup_time"},
      "requested_pick_up_date": {"source": "main_order_info.order_date"},
      "number_of_guests": {"source": "main_order_info.guest_count"},
      "delivery": {"source": "main_order_info.delivery_type"}
    },

    "group_orders": {
      "group_order_number": {"source": "main_order_info.order_number"},
      "pick_time": {"source": "main_order_info.pickup_time"}
    },

    "individual_orders": {
      "group_order_number": {"source": "main_order_info.order_number"},
      "guest_name": {"source": "individual_orders.guest_name"},
      "item_name": {"source": "individual_orders.item_name"},
      "modifications": {"source": "individual_orders.modifications"},
      "comments": {"source": "individual_orders.special_instructions"}
    }
  },

  "examples": {
    "slip_sample": {
      "input": "Slip 1 of 1\nA. Chu FL2\n1x Baked Falafel Bowl\n• Dressing Choice: Tera Vinaigrette\n• Extra Hummus\nSP: No onions please",
      "expected_output": {
        "guest_name": "A. Chu",
        "floor_location": "FL2",
        "item_name": "Baked Falafel Bowl",
        "modifications": ["Dressing Choice: Tera Vinaigrette", "Extra Hummus"],
        "comments": "No onions please"
      }
    },

    "table_row_sample": {
      "input": "1x Beef Kebab Bowl Q. Oto FL3 $15.95\nProtein Substitution + x1 Chicken Shawarma",
      "expected_output": {
        "guest_name": "Q. Oto",
        "floor_location": "FL3",
        "item_name": "Beef Kebab Bowl",
        "price": 15.95,
        "modifications": ["Protein Substitution: Chicken Shawarma"]
      }
    }
  }
}
